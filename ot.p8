  cam_y=screen_s
 },
 {
  sfx=10,
  cam_x=screen_s*7,
  cam_y=screen_s
 }
}

function load_stage(n)
 stage = n
 
 if n == 0 then
  load_start()
 else
  e_spawn = true
  p_move = true
  if n < 9 then
   p1.y = init_p_y
   p2.y = init_p_y
   p1.x = screen_s*(n-1)+init_p1_x
   p2.x = screen_s*(n-1)+init_p2_x
  else
   p1.y = screen_s + init_p_y
   p2.y = screen_s + init_p_y
   p1.x = screen_s*(n-9)+init_p1_x
   p2.x = screen_s*(n-9)+init_p2_x
  end
  sfx(stages[n].sfx)
 end
end

function load_start()
 p_move = false
 e_spawn = false
 sfx(stages[1].sfx)
end

function update_start()
 if btnp(0) or btnp(1) then
  if p.name == "p1" then
   p=p2
   bot=p1
  else
   p=p1
   bot=p2
  end
 end
 
 if btnp(4) or btnp(5) then
  load_stage(9)
 end
end

function draw_start()
 rect(p.x-2,
  p.y-2,
  p.x+18,
  p.y+18,
  1)
  
  say(58,110,
   "⬅️   JENN CHAD    ➡️",
   0, true)
   
  say(58,120,
   "PRESS ❎/🅾️ TO START",
   0, true)
end
