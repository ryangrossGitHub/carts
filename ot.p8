function load_stage(n)
 stage = n
 
 if n == 0 then
  load_start()
 elseif n == 1 then
  e_spawn = true
  p_move = true
 else
  e_spawn_s_cnt = 0
  sfx(stages[n].sfx)

  -- 8 to 9 is transition inside
  if n == 9 then
   p1.y = screen_s + init_p_y
   p2.y = screen_s + init_p_y-16
   p1.x = 16
   p2.x = 16
   cam_y = screen_s
   cam_x = 0
   e_spawn = true
   p_move = true
  else
   stage_trans = true
   e_spawn = false
   p_move = false
   p1.f = false
   p2.f = false
  end
 end
end

function update_stage_trans()
 if stfc < stft then
  stfc += 1
  p1.x += 1
  p2.x += 1
  cam_x += 1
 else
  stage_trans = false
  if stage < 16 then
	  stfc = 0
	  e_spawn = true
	  p_move = true
  end
 end
end

function load_start()
 p_move = false
 e_spawn = false
 cam_x = 0
 cam_y = 0
 sfx(stages[1].sfx)
 p1.y = init_p_y
 p2.y = init_p_y
 p1.x = init_p1_x
 p2.x = init_p2_x
end

function update_start()
 if btnp(0) or btnp(1) then
  if p.name == "p1" then
   p=p2
   bot=p1
  else
   p=p1
   bot=p2
  end
 end
 
 if btnp(4) or btnp(5) then
  load_stage(9)
 end
end

function draw_start()
 rect(p.x-2,
  p.y-2,
  p.x+18,
  p.y+18,
  1)
  
  say(58,110,
   "⬅️   JENN CHAD    ➡️",
   0, true)
   
  say(58,120,
   "PRESS ❎/🅾️ TO START",
   0, true)
end
