-- players --
p_move = false

init_p1_x = 47
init_p2_x = 65
init_p_y = 80

p1 = {
 name="p1",
 s={34,32}, -- spr in animation
 si=1, -- animation frame index
 f=true, -- flip sprite?
 x=init_p1_x, -- position
 y=init_p_y, -- position
 lafx=init_p1_x, -- last anima frame x
 lafy=init_p_y, -- last anima frame y
 afd=5, -- anima frame delay
 wpn=1 -- weapon: 0 pistol, 1 shotgun
}

p2 = {
 name="p2",
 s={2,0}, -- spr in animation
 si=1, -- animation frame index
 f=false, -- flip sprite?
 x=init_p2_x, -- position
 y=init_p_y, -- position
 lafx=init_p2_x, -- last anima frame x
 lafy=init_p_y, -- last anima frame y
 afd=5, -- anima frame delay
 wpn=0 -- weapon: 0 pistol, 1 shotgun
}

boss={
 x=992,
 y=216
}

p=p1
bot=p2

trigger_p = false

sgun = { -- shotgun
 delay=30,
 cnt=0
}

pstol = { -- pistol
 delay=5,
 cnt=0
}

function update_bot()
 local c,y = closest_enemy()
 if c then
	 if c < 0 then
	  bot.f = true
	  
	  if bot.x > cam_x+32 then
	   bot.x -= 1
	  end
	 else
	  bot.f = false
	  	  
	  if bot.x < cam_x+screen_s-32 then
	   bot.x += 1
	  end
	 end
	 bot_fire()
	end
	
	if y < 0 then
	 bot.y -= 1
	elseif y > 0 then
	 bot.y += 1
	end
end

function closest_enemy()
 -- which direction to fire
 local closest = 99
 -- neg = left, pos = right
 local c_xdir = 0
 
 -- which direction to move
 -- neg = up, pos = down
 local e_ydir = 0
 
 local hbox = 4 -- hit box
 
 if bot.wpn == 1 then
  hbox = 12
 end
 
 for e in all(enemies) do
  if e.dead == 0 and 
   e.x > cam_x+5 and
   e.x < cam_x+screen_s-5
   then
   -- if left or right then
   -- fire at closest enemy
   -- otherwise calculate
   -- whether there are more
   -- enemies above or below
   -- to dictate y movement
   
   if (e.y > bot.y-hbox 
    and e.y < bot.y+hbox) 
    then
      
	   local dir = e.x-bot.x
	   local dif = abs(dir)
	   if dif < closest then
	    closest = dif
	    c_xdir = dir
	   end
	  elseif e.y < bot.y then
	   e_ydir -= 1
	  else
	   e_ydir += 1
   end
  end
 end
 
 if closest == 99 then
  -- no enemies in range
  return nil, e_ydir
 else
  return c_xdir, e_ydir
 end
end

function bot_fire()
 if bot.wpn == 0 then
  if pstol.cnt == 0 then
   pstol.cnt = pstol.delay
  	sfx(0)
  	enemy_coll_detect(bot)
  end
 elseif bot.wpn == 1 then
  if sgun.cnt == 0 then
   sgun.cnt = sgun.delay
   sfx(1)
   enemy_coll_detect(bot)
  end
 end
end

function update_player_anims(p)
 if abs(p.x - p.lafx) 
  > p.afd or 
  abs(p.y - p.lafy) 
  > p.afd then

  p.lafx = p.x
  p.lafy = p.y
  
  -- get next animation frame
  p.si=(p.si % #p.s) + 1
 end
end

function draw_boss(armed)
 if armed then
	 spr(36,boss.x,boss.y,
  	2,2,false,false)
 else
  spr(38,boss.x,boss.y,
  	2,2,false,false)
 end
end
