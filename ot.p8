pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- main --

-- todo --
-- sfx
-- dialog
-- game ending

debug = ""
screen_s = 128

function _init()
 palt(9, true)
 palt(0, false)
 load_stage(0)
end

function _update()

 if stage == 0 then
  update_start()
 elseif stage_trans then
  update_stage_trans()
 else
  if stages[stage].e_cnt >
	  e_spawn_s_cnt then
		 
		 e_spawn_d_cnt += 1
		 
		 if e_spawn and
		  e_spawn_d_cnt >= stages[stage].e_spwd 
		  then
		  
		  spawn_enemy(stages[stage].e_spd)
		  e_spawn_d_cnt = 0
		  e_spawn_s_cnt += 1
		 end
	 else
	  local all_dead = true
		 for e in all(enemies) do
		 	if e.dead == 0 then
		 	 all_dead = false
		 	 break
		 	end
		 end
		 	
	  if all_dead then
	   enemies = {} -- clear
		  load_stage(stage+1)
		 end
	 end
 end
 
 if p_move then
	 if btn(0) and p.x>cam_x  then
	  p.x -= 1
	  p.f = true 
	 elseif btn(1) and p.x<cam_x + 
	  screen_s - 16 then
	  p.x += 1
	  p.f = false
	 end
	 
	 if btn(2) and p.y > 
	  flr(stage/9)*screen_s+42 then
	  p.y -= 1
	 elseif btn(3) and p.y < 
	  flr(stage/9)*screen_s+110 then
	  p.y += 1
	 end
	 
	 if btn(❎) or btn(🅾️) then
	  if not trigger_p then
	 	 if p.wpn == 0 then
	 	  if pstol.cnt == 0 then
	 	   pstol.cnt = pstol.delay
	 	  	sfx(0)
	 	  	enemy_coll_detect(p)
	 	  end
	 	 elseif p.wpn == 1 then
	 	  if sgun.cnt == 0 then
	 	   sgun.cnt = sgun.delay
	 	   sfx(1)
	 	   enemy_coll_detect(p)
	 	  end
	 	 end
	  end
	  
	  trigger_p = true
	 else
	  trigger_p = false
	 end
	end
 
 if sgun.cnt > 0 then
  sgun.cnt -= 1
 end

 if pstol.cnt > 0 then
  pstol.cnt -= 1
 end
 
 update_bot()
 update_enemies()
 update_player_anims(p)
 update_player_anims(bot)
end

function _draw()
 cls()
 map(0,0)
 
 local s=stages[stage]
 if not s then
  s = stages[1]
 end
 
 camera(cam_x,cam_y)
 draw_enemies()
 draw_particles(particles)
 spr(p.s[p.si],p.x,p.y,
  2,2,p.f,false)
 spr(bot.s[bot.si],bot.x,bot.y,
  2,2,bot.f,false)
 say(58,12,"DONUTS ♥", 0, false)
 say(screen_s + 58,
  12,"COFFEE ●", 0, false)
 say(screen_s*2 + 58,
  12,"PARKING ★", 0, false)
 say(screen_s*3 + 29,
  17,"ICE CREAM", 0, false)
 say(screen_s*5 + 37,
  40,"WATER TREATEMENT PLANT ∧",
   0, false)
 say(screen_s*7 + 32,
  49,"danger! DO NOT ENTER",
   0, false)
 
 if stage == 0 then
  draw_start()
 elseif stage == 16 then
  if stage_trans == false then
   ending_dialog()
  end
 end


 --say(p.x,p.y, debug, 1)
end
-->8
-- particles --

particles = {}

function particle(x,y, 
 x_speed, y_speed, clr, life)
	local p = {
  x = x,
  y = y,
  x_speed = x_speed,
  y_speed = y_speed,
  clr = clr, -- pixel color
  life = life, -- frames until deletion
	}

	return p
end

function draw_particles(particles)
	for p in all(particles) do
		p.y += p.y_speed
		p.x += p.x_speed
		p.life -= 1

		if p.life > 0 then
		 pset(p.x, p.y, p.clr)
		else
	  del(particles, p)
		end
	end
end

