end_dialog_delay = 150
end_dialog_cnt = 0
end_dt_cnt = 1
end_dt = {
	{"p2", "HEY! PUT'EM UP"},
 {"e", "UH, I'M SORRY, MY WIFE AND DAUGHTER WERE TAKEN"},	
