pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
p1 = {
 s=0, -- sprite number
 f=false, -- flip sprite?
 x=56, -- position
 y=58, -- position
 lafx=56, -- last anima frame x
 lafy=58, -- last anima frame y
 afd=5, -- anima frame delay
}

p2 = {
 s=34,
 f=false,
 x=56,
 y=100,
 afd=5,
 afc=0, -- anima frame count
}

e = {
 s=8,
 f=false,
 x=100,
 y=60,
 afd=20,
 afc=0,
 dead=0
}

debug = ""

function _init()
 palt(9, true)
 palt(0, false)
end

function _update()
 if btn(0) then
  p1.x -= 1
  p1.f = true 
 elseif btn(1) then
  p1.x += 1
  p1.f = false
 end
 
 if btn(2) then
  p1.y -= 1
 elseif btn(3) then
  p1.y += 1
 end
 
 if btnp(❎) or btnp(🅾️) then
   sfx(0)
   e.dead=1
   e.s = 12
   
   for i=1,20 do
   	local xs = rnd(3 - 0) + 0
		  local ys = rnd(1 - -1) + -1
    add(particles, 
     particle(e.x+4,e.y,
      xs,ys,3,10))
   end 
 end
 
 if e.dead == 1 then
  e.afc += 1
  
  if e.afc >= e.afd then
	  e.afc = 0
	  
	  if e.s == 12 then
	   e.s = 14
	  end
	 end
 end
 
 if abs(p1.x - p1.lafx) 
  > p1.afd or 
  abs(p1.y - p1.lafy) 
  > p1.afd then

  p1.lafx = p1.x
  p1.lafy = p1.y
  
  if p1.s == 0 then
   p1.s = 2
  else
   p1.s = 0
  end
 end
 
 p2.afc += 1
 if p2.afc >= p2.afd then
  p2.afc = 0
  
  if p2.s == 34 then
   p2.s = 32
  elseif p2.s == 32 then
   p2.s = 36
  else
   p2.s = 34
  end
 end
end

function _draw()
 cls()
 map(0,0)
 spr(e.s,e.x,e.y,2,2,e.f,false)
 draw_particles(particles)
 spr(p1.s,p1.x,p1.y,
  2,2,p1.f,false)
 spr(p2.s,p2.x,p2.y,
  2,2,p2.f,false)
 print(debug)
end
-->8
-- particles --

particles = {}

function particle(x,y, 
 x_speed, y_speed, clr, life)
	local p = {
  x = x,
  y = y,
  x_speed = x_speed,
  y_speed = y_speed,
  clr = clr, -- pixel color
  life = life, -- frames until deletion
	}

	return p
end

function draw_particles(particles)
	for p in all(particles) do
		p.y += p.y_speed
		p.x += p.x_speed
		p.life -= 1

		if p.life > 0 then
		 pset(p.x, p.y, p.clr)
		else
	  del(particles, p)
		end
	end
end

