pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- main --
debug = ""
screen_s = 128

function _init()
 palt(9, true)
 palt(0, false)
 load_stage(0)
end

function _update()

 if stage == 0 then
  update_start()
 end

 e_spawn_cnt += 1
 
 if e_spawn and 
  e_spawn_cnt >= e_spawn_delay 
  then
  
  spawn_enemy(e_speed)
  e_spawn_cnt = 0
 end
 
 if p_move then
	 if btn(0) and p.x > 
	  stages[stage].cam_x  then
	  p.x -= 1
	  p.f = true 
	 elseif btn(1) and p.x < 
	  stages[stage].cam_x + 
	  screen_s - 16 then
	  p.x += 1
	  p.f = false
	 end
	 
	 if btn(2) and p.y > 
	  flr(stage/9)*screen_s+42 then
	  p.y -= 1
	 elseif btn(3) and p.y < 
	  flr(stage/9)*screen_s+110 then
	  p.y += 1
	 end
	 
	 if btn(❎) or btn(🅾️) then
	  if not trigger_p then
	 	 if p.wpn == 0 then
	 	  if pstol.cnt == 0 then
	 	   pstol.cnt = pstol.delay
	 	  	sfx(0)
	 	  	enemy_coll_detect(p)
	 	  end
	 	 elseif p.wpn == 1 then
	 	  if sgun.cnt == 0 then
	 	   sgun.cnt = sgun.delay
	 	   sfx(1)
	 	   enemy_coll_detect(p)
	 	  end
	 	 end
	  end
	  
	  trigger_p = true
	 else
	  trigger_p = false
	 end
	end
 
 if sgun.cnt > 0 then
  sgun.cnt -= 1
 end

 if pstol.cnt > 0 then
  pstol.cnt -= 1
 end
 
 update_bot()
 update_enemies()
 update_player_anims(p)
 update_player_anims(bot)
end

function _draw()
 cls()
 map(0,0)
 
 local s=stages[stage]
 if not s then
  s = stages[1]
 end
 
 camera(s.cam_x,s.cam_y)
 draw_enemies()
 draw_particles(particles)
 spr(p.s[p.si],p.x,p.y,
  2,2,p.f,false)
 spr(bot.s[bot.si],bot.x,bot.y,
  2,2,bot.f,false)
 say(58,12,"DONUTS ♥", 0, false)
 say(screen_s + 58,
  12,"COFFEE ●", 0, false)
 say(screen_s*2 + 58,
  12,"PARKING ★", 0, false)
 say(screen_s*3 + 29,
  17,"ICE CREAM", 0, false)
 say(screen_s*5 + 37,
  40,"WATER TREATEMENT PLANT ∧",
   0, false)
 say(screen_s*7 + 32,
  49,"danger! DO NOT ENTER",
   0, false)
 --say(p.x,p.y, "WHAT THE?", 1)
 
 if stage == 0 then
  draw_start()
 end

 print(debug)
end
-->8
-- particles --

particles = {}

function particle(x,y, 
 x_speed, y_speed, clr, life)
	local p = {
  x = x,
  y = y,
  x_speed = x_speed,
  y_speed = y_speed,
  clr = clr, -- pixel color
  life = life, -- frames until deletion
	}

	return p
end

function draw_particles(particles)
	for p in all(particles) do
		p.y += p.y_speed
		p.x += p.x_speed
		p.life -= 1

		if p.life > 0 then
		 pset(p.x, p.y, p.clr)
		else
	  del(particles, p)
		end
	end
end

-->8
-- dialog --

function say(x,y,msg,border,wide)
  -- 1. split text into words using pico-8's native split
  local max_w = 42 
  local words = split(msg, " ")
  local lines = {}
  local curr = ""
  
  if wide then
   max_w = 81
  end

  for w in all(words) do
    -- puny font characters are ~4 pixels wide
    if #curr * 4 + #w * 4 + 6 
     > max_w then
      add(lines, curr)
      curr = w
    else
      curr = (curr == "") and w or curr.." "..w
    end
  end
  add(lines, curr)

  -- 2. calculate dimensions (puny is 5px tall)
  local line_h = 6 
  local b_w = max_w
  local b_h = #lines * line_h + 3
  local bx = x - b_w/2 + 8
  local by = y - b_h - 2

  -- 3. draw bubble body and tail
  rectfill(bx, by, bx+b_w, by+b_h, 7)
  
  if border==1 then
   rect(bx, by, bx+b_w, by+b_h, 0)
  
	  -- simple triangle tail
	  line(x+6, by+b_h, x+7, by+b_h+2, 0)
	  line(x+8, by+b_h, x+7, by+b_h+2, 0)
	  pset(x+7, by+b_h, 7)
  end

  -- 4. print each line with \v (puny font)
  for i=1,#lines do
    print(lines[i], bx+2, by+2 + (i-1)*line_h, 0)
  end
end

-->8
-- enemies --

enemies = {}

e_spawn = false
e_speed = 0.5
e_spawn_cnt = 0
e_spawn_delay = 15

function spawn_enemy(speed)
 add(enemies, {
	 s=8,
	 spd=speed, -- movement speed
	 f=true,
	 x=rnd({
	 	stages[stage].cam_x-16,
	 	stages[stage].cam_x+screen_s+16}),
	 y=rnd(56) + flr(stage/9)*screen_s+56,
	 d_afd=20, -- death anim frm delay
	 d_afc=0, -- death anim frm cnt
	 dead=0,
	 afd=7, -- anima frame delay
	 afc=0,
	})
end

function update_enemies()
 for e in all(enemies) do
	 if e.dead == 1 then
	  e.d_afc += 1
	  
	  if e.d_afc >= e.d_afd then
		  e.d_afc = 0
		  
		  if e.s == 12 then
		   e.s = 14
		  elseif e.s == 44 then
		   e.s = 46
		  end
		 end
	 else
	  if p.x < e.x - e.spd then
	   e.x -= e.spd
	   e.f = false
	  elseif p.x > e.x + e.spd then
	   e.x += e.spd
	   e.f = true
	  end
	  
	  -- walk to middle before down
	  if abs(p.x-e.x) < 2 then
		  if p.y < e.y - e.spd then
		   e.y -= e.spd
		  elseif p.y > e.y + e.spd then
		   e.y += e.spd
		  end
	  end
	  
	  e.afc += 1
	  
	  if e.afc >= e.afd then
	   e.afc = 0
	   if e.s == 8 then
	    e.s = 10
	   else
	    e.s = 8
	   end
	  end 
	 end
 end
end

function draw_enemies()
 for e in all(enemies) do
  spr(e.s,e.x,e.y,2,2,e.f,false)
 end
end

function enemy_coll_detect(p) 
 local hbox = 4 -- hit box
 
 if p.wpn == 1 then
  hbox = 12
 end
 
 for e in all(enemies) do
  if e.dead == 0 and 
   ((e.x-2 < p.x and p.f) or
   (e.x+2 > p.x and not p.f)) and 
   (e.y > p.y-hbox and e.y < p.y+hbox) 
   then
      
   e.dead=1
   
   for i=1,20 do
   	local xs = rnd(3 - 0) + 0
		  local ys = rnd(1 - -1) + -1
    add(particles, 
     particle(e.x+4,e.y,
      xs,ys,3,10))
   end
  
   if p.wpn == 0 then
 	  e.s = 12
 	  return -- pistol hits 1 at a time
 	 elseif p.wpn == 1 then
 	  e.s = 46
 	 end
  end
 end
end
