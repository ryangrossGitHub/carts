pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
m = 8 -- sprite size multiplier
yrd = 4 -- pixel to yrd multiplier
white = 7
max_a = 9 -- max aim in spr
sprd = 2 -- spread multiplier

ball = {
 x = 0,
 y = 7
}

aim = {
 x = ball.x-1+max_a,
 y = ball.y,
 r = 2,
}

function _init()

end

function _update()
 if btn(0) 
  and aim.x > 0 
  and aim_d()-1 <= max_a then
 	aim.x -= 0.5
 elseif btn(1) 
  and aim.x < 16
  and aim_d()+1 <= max_a then
  aim.x += 0.5
 end
 
 if btn(2) 
  and aim.y > 0
  and aim_d()+1 <= max_a then
  aim.y -= 0.5
 elseif btn(3) 
  and aim.y < 16
  and aim_d()+1 <= max_a then
  aim.y += 0.5
 end
end

function _draw()
 cls()
 map(0,0)
 bx,by = cntr(ball.x,ball.y)
 pset(bx,by,white)
 
 tx,ty = cntr(
  aim.x,
  aim.y
 )
 line(bx,by,tx,ty, white)
 
 r=abs(ball.x-aim.x)*sprd
 circ(tx,ty,r)
end

function cntr(x,y)
 return x*m+m/2, y*m+m/2 
end

function aim_d() -- aim distance
 return dist(ball.x,ball.y,
  aim.x,aim.y)
end

function dist(x1, y1, x2, y2)
  local dx = x2 - x1
  local dy = y2 - y1
  return sqrt(dx * dx + dy * dy)
end
